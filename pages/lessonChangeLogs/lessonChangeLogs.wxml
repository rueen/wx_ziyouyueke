<!--pages/lessonChangeLogs/lessonChangeLogs.wxml-->
<navBar title="课时变更明细" />
<layout>
  <view class="page-container">
    <view class="page-tip">
      <text>课时变动记录仅包含 {{logStartDateText}} 之后的数据</text>
    </view>

    <!-- 筛选 -->
    <view class="filter-card">
      <view class="filter-header" bindtap="onToggleFilter">
        <view class="filter-header-left">
          <text class="filter-header-title">筛选条件</text>
          <text class="filter-active-tag" wx:if="{{hasActiveFilter}}">已筛选</text>
        </view>
        <text class="iconfont icon-arrow-d filter-toggle-icon {{showFilterPanel ? 'expanded' : ''}}"></text>
      </view>
      <view wx:if="{{showFilterPanel}}" class="filter-body">
      <view class="filter-row">
        <text class="filter-label">课程分类</text>
        <picker
          mode="selector"
          range="{{categoryPickerRange}}"
          range-key="name"
          value="{{categoryPickerIndex}}"
          bindchange="onCategoryPickerChange"
        >
          <view class="filter-value">
            <text>{{selectedCategoryName}}</text>
            <text class="iconfont icon-arrow-r"></text>
          </view>
        </picker>
      </view>
      <view class="filter-row">
        <text class="filter-label">变动类型</text>
        <picker
          mode="selector"
          range="{{changeTypeOptions}}"
          range-key="label"
          value="{{changeTypePickerIndex}}"
          bindchange="onChangeTypePickerChange"
        >
          <view class="filter-value">
            <text>{{selectedChangeTypeName}}</text>
            <text class="iconfont icon-arrow-r"></text>
          </view>
        </picker>
      </view>
      <view class="filter-row">
        <text class="filter-label">开始日期</text>
        <picker mode="date" value="{{filterStartDate}}" bindchange="onFilterStartDateChange">
          <view class="filter-value">
            <text>{{filterStartDate || '不限'}}</text>
            <text class="iconfont icon-arrow-r"></text>
          </view>
        </picker>
      </view>
      <view class="filter-row">
        <text class="filter-label">结束日期</text>
        <picker mode="date" value="{{filterEndDate}}" bindchange="onFilterEndDateChange">
          <view class="filter-value">
            <text>{{filterEndDate || '不限'}}</text>
            <text class="iconfont icon-arrow-r"></text>
          </view>
        </picker>
      </view>
      <view class="filter-actions">
        <view class="filter-btn" bindtap="onClearFilter">清除</view>
        <view class="filter-btn primary" bindtap="onApplyFilter">查询</view>
      </view>
      </view>
    </view>

    <view class="log-list" wx:if="{{logs.length > 0}}">
      <view class="log-item" wx:for="{{logs}}" wx:key="id">
        <view class="log-header">
          <view class="log-type log-type-{{item.change_type}}">{{item.change_type_text}} {{item.remark || ''}}</view>
          <text class="log-time">{{item.displayTime}}</text>
        </view>
        <view class="log-body">
          <view class="log-row">
            <text class="log-label">课程分类</text>
            <text class="log-value">{{item.categoryName}}</text>
          </view>
          <view class="log-row">
            <text class="log-label">变动数量</text>
            <text class="log-value">{{item.change_amount}} 节</text>
          </view>
          <view class="log-row">
            <text class="log-label">剩余课时</text>
            <text class="log-value">{{item.before_lessons}} → {{item.after_lessons}}</text>
          </view>
          <view class="log-row">
            <text class="log-label">课单价</text>
            <text class="log-value">{{item.unitPriceDisplay}}</text>
          </view>
        </view>
      </view>
    </view>

    <emptyState
      wx:elif="{{!loading}}"
      type="no-data"
      title="暂无变更记录"
      description="常规课课时调整或消课后会自动生成记录"
    />

    <view class="load-more-container" wx:if="{{logs.length > 0}}">
      <text wx:if="{{loadingMore}}" class="load-more-text">加载中...</text>
      <text wx:elif="{{hasMore}}" class="load-more-text">上拉加载更多</text>
      <text wx:else class="load-more-text">已加载全部记录</text>
    </view>
  </view>
</layout>
