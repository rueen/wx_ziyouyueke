@import '/style/iconfont.wxss';

page {
  min-height: 100vh;
  background: #f5f5f5;
}

.page-container {
  padding: 16rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.log-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.log-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.log-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.log-type {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #ffffff;
}

.log-type-1 {
  background: #34c759;
}

.log-type-2 {
  background: #ff9500;
}

.log-type-3 {
  background: #ff3b30;
}

.log-time {
  font-size: 24rpx;
  color: #86868b;
}

.log-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
}

.log-label {
  font-size: 26rpx;
  color: #86868b;
}

.log-value {
  font-size: 26rpx;
  color: #1d1d1f;
}

.load-more-container {
  padding: 32rpx 0;
  text-align: center;
}

.load-more-text {
  font-size: 24rpx;
  color: #86868b;
}
