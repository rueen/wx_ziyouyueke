@import '/style/iconfont.wxss';

page {
  min-height: 100vh;
  background: #f5f5f5;
}

.page-container {
  padding: 16rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.page-tip {
  margin-bottom: 16rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  background: #fff8e6;
  font-size: 24rpx;
  color: #996600;
  line-height: 1.5;
}

.filter-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 0 24rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.filter-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
}

.filter-header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.filter-header-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.filter-active-tag {
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  background: #e8f2ff;
  color: #007aff;
  font-size: 22rpx;
}

.filter-toggle-icon {
  font-size: 24rpx;
  color: #999999;
  transition: transform 0.2s ease;
}

.filter-toggle-icon.expanded {
  transform: rotate(180deg);
}

.filter-body {
  padding-bottom: 24rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f2f2f2;
}

.filter-label {
  font-size: 28rpx;
  color: #333333;
  flex-shrink: 0;
}

.filter-value {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  font-size: 28rpx;
  color: #666666;
  max-width: 420rpx;
}

.filter-value .iconfont {
  font-size: 24rpx;
  color: #999999;
}

.filter-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 24rpx;
}

.filter-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 36rpx;
  background: #f2f2f7;
  color: #333333;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.filter-btn.primary {
  background: #007aff;
  color: #ffffff;
}

.log-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.log-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.log-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.log-type {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #ffffff;
}

.log-type-1 {
  background: #34c759;
}

.log-type-2 {
  background: #ff9500;
}

.log-type-3 {
  background: #ff3b30;
}

.log-time {
  font-size: 24rpx;
  color: #86868b;
}

.log-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
}

.log-label {
  font-size: 26rpx;
  color: #86868b;
}

.log-value {
  font-size: 26rpx;
  color: #1d1d1f;
}

.load-more-container {
  padding: 32rpx 0;
  text-align: center;
}

.load-more-text {
  font-size: 24rpx;
  color: #86868b;
}
