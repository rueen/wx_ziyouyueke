<!--pages/studentCards/studentCards.wxml-->
<navBar title="{{studentName}}的课程卡" />
<layout>
  <view class="student-cards-container">

    <!-- 空状态 -->
    <empty-state 
      wx:if="{{!loading && cardList.length === 0}}"
      title="暂无课程卡"
      description="点击下方按钮为学员添加课程卡"
    />

    <!-- 卡片列表 -->
    <view wx:else class="card-list">
      <view 
        wx:for="{{cardList}}" 
        wx:key="id" 
        class="card-item"
        bindtap="onViewDetail"
        data-card="{{item}}"
      >
        <!-- 卡片内容 -->
        <view class="card-content" style="background-color: {{item.card_color}};">
          <view class="card-header">
            <view class="card-name">{{item.card_name}}</view>
            <view class="card-status {{item.is_expired ? 'expired' : ''}}">
              {{item.is_expired ? '已过期' : item.card_status_text}}
            </view>
          </view>
          
          <view class="card-body">
            <view class="card-lessons">
              <text wx:if="{{item.is_unlimited}}">不限次数</text>
              <text wx:else>剩余 {{item.remaining_lessons}}/{{item.total_lessons}} 节</text>
            </view>
            <view class="card-used">
              <text>已消耗 {{item.used_count}} 次</text>
            </view>
          </view>

          <view class="card-footer" wx:if="{{!(item.card_status === 0 && !item.is_expired)}}">
            <text class="expire-date">有效期至 {{item.expire_date}}</text>
          </view>
        </view>

        <!-- 操作按钮 -->
        <view class="card-actions" catchtap="onPreventClose">
          <!-- 未开启状态：显示编辑、开卡、删除 -->
          <block wx:if="{{item.card_status === 0 && !item.is_expired}}">
            <view class="action-btn" catchtap="onEditCard" data-card="{{item}}">
              <text>编辑</text>
            </view>
            <view class="action-btn" catchtap="onActivateCard" data-card="{{item}}">
              <text>开卡</text>
            </view>
            <view class="action-btn danger" catchtap="onDeleteCard" data-card="{{item}}">
              <text>删除</text>
            </view>
          </block>

          <!-- 已开启状态：显示停卡 -->
          <block wx:if="{{item.card_status === 1 && !item.is_expired}}">
            <view class="action-btn" catchtap="onEditCard" data-card="{{item}}">
              <text>编辑</text>
            </view>
            <view class="action-btn warning" catchtap="onDeactivateCard" data-card="{{item}}">
              <text>停卡</text>
            </view>
          </block>

          <!-- 已停用状态：显示编辑、重新开启、删除 -->
          <block wx:if="{{item.card_status === 2 && !item.is_expired}}">
            <view class="action-btn" catchtap="onEditCard" data-card="{{item}}">
              <text>编辑</text>
            </view>
            <view class="action-btn" catchtap="onReactivateCard" data-card="{{item}}">
              <text>重新开启</text>
            </view>
            <view class="action-btn danger" catchtap="onDeleteCard" data-card="{{item}}">
              <text>删除</text>
            </view>
          </block>

          <!-- 已过期状态：只显示删除 -->
          <block wx:if="{{item.is_expired}}">
            <view class="action-btn" catchtap="onEditCard" data-card="{{item}}">
              <text>编辑</text>
            </view>
            <view class="action-btn danger" catchtap="onDeleteCard" data-card="{{item}}">
              <text>删除</text>
            </view>
          </block>
        </view>
      </view>
    </view>

    <!-- 添加按钮 -->
    <view class="add-button-container">
      <button class="add-button" bindtap="onShowAddModal">添加课程卡</button>
    </view>

    <!-- 添加卡片弹窗 -->
    <view wx:if="{{showAddModal}}" class="modal-mask" bindtap="onHideAddModal">
      <view class="modal-content" catchtap="onPreventClose">
        <view class="modal-header">
          <text class="modal-title">选择卡片模板</text>
          <text class="iconfont icon-close" bindtap="onHideAddModal"></text>
        </view>

        <view class="modal-body">
          <view class="template-list">
            <view 
              wx:for="{{templateList}}" 
              wx:key="id"
              class="template-item {{selectedTemplateId === item.id ? 'active' : ''}}"
              bindtap="onSelectTemplate"
              data-id="{{item.id}}"
            >
              <view class="template-preview" style="background-color: {{item.card_color}};">
                <view class="template-name">{{item.card_name}}</view>
                <view class="template-info">
                  <text wx:if="{{item.is_unlimited}}">不限次数</text>
                  <text wx:else>{{item.card_lessons}}节课</text>
                  <text class="divider">•</text>
                  <text>{{item.valid_days}}天</text>
                </view>
                <view wx:if="{{item.card_desc}}" class="template-desc">{{item.card_desc}}</view>
              </view>
              <view wx:if="{{selectedTemplateId === item.id}}" class="selected-icon">
                <text class="iconfont icon-right"></text>
              </view>
            </view>
          </view>
        </view>

        <view class="modal-footer">
          <view class="btn btn-cancel" bindtap="onHideAddModal">取消</view>
          <view class="btn btn-primary" bindtap="onConfirmAdd">确定</view>
        </view>
      </view>
    </view>
  </view>
</layout>
<!-- 编辑卡片实例 -->
<modal 
  show="{{showModal}}" 
  title="编辑卡片实例" 
  position="center"
  bind:close="onModalClose"
>
  <view class="edit-form">
    <!-- 单次销课扣减课时（所有状态均可编辑） -->
    <view class="edit-form-item">
      <view class="edit-form-label">单次销课扣减课时</view>
      <view class="edit-form-tip">每次销课或活动签到时从卡内扣除的课时数，最小值为 1。适用于「一张卡多人同时使用」场景。</view>
      <view class="edit-number-input">
        <view class="number-btn" catchtap="onDeductLessonsDecrement">－</view>
        <input
          class="number-value"
          type="number"
          value="{{editDeductLessons}}"
          bindinput="onDeductLessonsInput"
        />
        <view class="number-btn" catchtap="onDeductLessonsIncrement">＋</view>
      </view>
    </view>

    <!-- 到期时间：未开卡（card_status === 0）不允许修改 -->
    <view class="edit-form-item" wx:if="{{editingCardStatus !== 0}}">
      <view class="edit-form-label">到期时间</view>
      <picker mode="date" value="{{editExpireDate}}" bindchange="onEditExpireDateChange">
        <view class="edit-date-picker">
          <text>{{editExpireDate || '请选择到期时间'}}</text>
          <text class="iconfont icon-arrow-r"></text>
        </view>
      </picker>
    </view>

    <!-- 课单价 -->
    <view class="edit-form-item">
      <view class="edit-form-label">课单价（元/课时）</view>
      <view class="edit-form-tip">留空则继承卡片模板单价{{editingTemplateUnitPriceText}}</view>
      <input
        class="edit-price-input"
        type="digit"
        placeholder="请输入课单价"
        value="{{editUnitPrice}}"
        bindinput="onUnitPriceInput"
      />
    </view>
  </view>
  <view class="edit-modal-footer">
    <view class="btn btn-cancel" bindtap="onModalClose">取消</view>
    <view class="btn btn-primary" bindtap="onConfirmEditCard">保存</view>
  </view>
</modal>
