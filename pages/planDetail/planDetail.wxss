/**
 * pages/planDetail/planDetail.wxss
 * 训练计划详情页面样式
 */
@import '/style/iconfont.wxss';

page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.container {
  padding: 16rpx 16rpx 140rpx;
}

.info-section {
  background-color: #fff;
  padding: 32rpx;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

.icon-section {
  display: flex;
  align-items: center;
}

.del-btn {
  font-size: 30rpx;
  color: #ff3b30;
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  margin-right: 10rpx;
}

.edit-btn {
  font-size: 40rpx;
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
}

.plan-name {
  font-size: 30rpx;
  color: #000;
  font-weight: 500;
}

.edit-input {
  height: 80rpx;
  background-color: #f8f9fa;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid #e9ecef;
  box-sizing: border-box;
}

.edit-input:focus {
  border-color: #007aff;
  background-color: #fff;
}

/* 内容区域 */
.content-container {
  width: 100%;
}

.content-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  word-break: break-all;
  white-space: pre-wrap;
}

.content-textarea {
  width: 100%;
  min-height: 200rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  border: 1rpx solid #e9ecef;
  line-height: 1.6;
}

.content-textarea:focus {
  border-color: #007aff;
  background-color: #fff;
}

.content-textarea::placeholder {
  color: #999;
}

/* 图片上传 */
.image-upload {
  width: 100%;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: calc(24.5% - 11rpx);
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #f5f5f5;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.delete-btn .iconfont {
  font-size: 24rpx;
  color: #fff;
}

.add-image-btn {
  width: calc(33.333% - 11rpx);
  aspect-ratio: 1;
  border: 2rpx dashed #c7c7cc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fafafa;
}

.add-image-btn:active {
  background-color: #f0f0f0;
}

.add-icon {
  font-size: 48rpx;
  color: #86868b;
  line-height: 1;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 24rpx;
  color: #86868b;
}

/* 可见性设置 */
.switch-container {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.switch-text {
  font-size: 28rpx;
  color: #333;
}

.visible-text {
  font-size: 28rpx;
  color: #333;
}

/* 编辑操作按钮 */
.edit-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  border-top: 1rpx solid #e9ecef;
  z-index: 10;
}

.cancel-btn,
.save-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-btn {
  background-color: #f8f9fa;
  color: #666;
  border: 1rpx solid #e9ecef;
}

.cancel-btn:active {
  background-color: #e9ecef;
}

.save-btn {
  background-color: #007aff;
  color: #fff;
}

.save-btn:active {
  background-color: #0056cc;
}

.cancel-btn::after,
.save-btn::after {
  border: none;
}
