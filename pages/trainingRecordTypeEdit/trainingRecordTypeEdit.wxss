page {
  height: 100vh;
  background-color: #f5f5f5;
}

.form-container { margin: 24rpx; background: #fff; border-radius: 16rpx; overflow: hidden; }
.form-item { padding: 28rpx 24rpx; border-bottom: 1rpx solid #f2f2f7; }
.form-item:last-child { border-bottom: none; }
.form-label { font-size: 26rpx; color: #86868b; margin-bottom: 12rpx; display: block; }
.form-input { font-size: 30rpx; color: #1d1d1f; width: 100%; }

/* 字段区域 */
.fields-section { padding-bottom: 16rpx; }
.fields-header { display: flex; align-items: baseline; gap: 8rpx; margin-bottom: 20rpx; }
.fields-hint { font-size: 22rpx; color: #c7c7cc; }

.field-list { display: flex; flex-direction: column; gap: 16rpx; }

.field-row { display: flex; align-items: center; gap: 16rpx; background: #f9f9fb; border-radius: 12rpx; padding: 0 16rpx; }
.field-input { flex: 1; height: 80rpx; font-size: 28rpx; color: #1d1d1f; }
.field-delete-btn { width: 48rpx; height: 48rpx; border-radius: 50%; background: #ff3b30; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.field-delete-icon { color: #fff; font-size: 36rpx; font-weight: 300; line-height: 1; margin-top: -2rpx; }

.field-add-btn { display: flex; align-items: center; gap: 10rpx; padding: 16rpx 0 4rpx; }
.field-add-icon { font-size: 36rpx; color: #007aff; line-height: 1; }
.field-add-text { font-size: 28rpx; color: #007aff; }

