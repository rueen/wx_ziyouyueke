<!--pages/planList/planList.wxml-->
<navBar title="{{studentName ? studentName + '的训练计划' : '训练计划'}}" />
<layout>
  <!-- 计划列表 -->
  <view class="plan-list" wx:if="{{plans.length > 0}}">
    <view class="plan-item" wx:for="{{plans}}" wx:key="id" bindtap="onPlanDetail" data-plan="{{item}}">
      <view class="plan-info">
        <view class="plan-name">{{item.plan_name}}</view>
        <view class="plan-meta">
          <text class="plan-date">{{item.created_at}}</text>
          <text class="plan-visible" wx:if="{{item.is_visible === 0}}">（学员不可见）</text>
        </view>
      </view>
      <text class="iconfont icon-arrow-r arrow-icon"></text>
    </view>
    
    <!-- 加载更多提示 -->
    <view class="load-more-container" wx:if="{{hasMore || isLoading}}">
      <view class="load-more-item" wx:if="{{isLoading}}">
        <text class="loading-text">加载中...</text>
      </view>
      <view class="load-more-item" wx:elif="{{hasMore}}">
        <text class="load-more-text">上拉加载更多</text>
      </view>
    </view>
    
    <!-- 没有更多数据提示 -->
    <view class="no-more-container" wx:if="{{!hasMore && !isLoading && plans.length > 0}}">
      <text class="no-more-text">已加载全部计划</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:elif="{{isLoading && plans.length === 0}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:else>
    <emptyState 
      type="no-data"
      title="暂无训练计划"
      description="点击右下角按钮添加新计划">
    </emptyState>
  </view>

  <!-- 添加计划按钮 -->
  <view class="add-button-container">
    <button class="add-button" bindtap="onAddPlan">添加计划</button>
  </view>
</layout>
