/**
 * pages/planList/planList.wxss
 * 训练计划列表页面样式
 */
@import '/style/iconfont.wxss';

page {
  height: 100vh;
  background-color: #f5f5f5;
}

/* 计划列表 */
.plan-list {
  display: flex;
  flex-direction: column;
  padding: 16rpx;
  gap: 16rpx;
  padding-bottom: 160rpx;
}

.plan-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 24rpx;
  border-radius: 16rpx;
}

.plan-item:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 计划信息 */
.plan-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.plan-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #1d1d1f;
  line-height: 1.4;
}

.plan-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #86868b;
}

.plan-date {
  font-size: 24rpx;
  color: #86868b;
}

.plan-visible {
  font-size: 24rpx;
  color: #ff9500;
}

.plan-content-preview {
  font-size: 28rpx;
  color: #515154;
  line-height: 1.5;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.arrow-icon {
  font-size: 32rpx;
  color: #c7c7cc;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* 加载更多 */
.load-more-container {
  padding: 32rpx 0;
  text-align: center;
}

.load-more-item {
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 28rpx;
  color: #86868b;
}

.load-more-text {
  font-size: 28rpx;
  color: #86868b;
}

.no-more-container {
  padding: 32rpx 0;
  text-align: center;
}

.no-more-text {
  font-size: 28rpx;
  color: #86868b;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

/* 添加按钮 */
.add-button-container {
  position: fixed;
  bottom: 32rpx;
  left: 0;
  right: 0;
  padding: 0 32rpx;
  z-index: 10;
}

.add-button {
  width: 100%;
  height: 88rpx;
  background-color: #1d1d1f;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.add-button:active {
  opacity: 0.8;
}
