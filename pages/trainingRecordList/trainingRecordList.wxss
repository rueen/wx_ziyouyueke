@import '/style/iconfont.wxss';

page {
  height: 100vh;
  background-color: #f5f5f5;
}

.manage-types-entry {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #fff;
  margin-bottom: 2rpx;
  text-align: right;
}
.manage-types-text {
  font-size: 28rpx;
  color: #007aff;
  flex: 1;
}
.manage-types-arrow {
  font-size: 24rpx;
  color: #007aff;
  margin-left: 12rpx;
}

.filter-bar {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 0 24rpx;
  margin-bottom: 16rpx;
  height: 88rpx;
}
.filter-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.filter-label {
  font-size: 28rpx;
  color: #333;
}
.filter-divider {
  width: 1rpx;
  height: 40rpx;
  background: #e5e5ea;
  margin: 0 16rpx;
}

.timeline { padding: 0 24rpx; }
.timeline-item { display: flex; position: relative; padding-bottom: 32rpx; }
.timeline-dot { width: 20rpx; height: 20rpx; border-radius: 50%; background: #007aff; flex-shrink: 0; margin-top: 12rpx; margin-right: 20rpx; }
.timeline-line { position: absolute; left: 9rpx; top: 32rpx; bottom: 0; width: 2rpx; background: #e5e5ea; }
.timeline-content { flex: 1; background: #fff; border-radius: 16rpx; padding: 24rpx; }

.record-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 12rpx; }
.record-meta { flex: 1; }
.record-type { display: inline-block; background: #e8f4ff; color: #007aff; font-size: 22rpx; border-radius: 6rpx; padding: 2rpx 10rpx; margin-bottom: 8rpx; }
.record-time { display: block; font-size: 24rpx; color: #86868b; }
.record-more { font-size: 36rpx; color: #86868b; padding: 0 8rpx; line-height: 1; }
.record-fields { display: flex; flex-wrap: wrap; gap: 12rpx 24rpx; margin-bottom: 12rpx; }
.record-field-item { display: flex; align-items: center; gap: 8rpx; }
.field-label { font-size: 24rpx; color: #86868b; }
.field-value { font-size: 26rpx; color: #1d1d1f; font-weight: 500; }
.record-content { font-size: 28rpx; color: #1d1d1f; line-height: 1.6; display: block; margin-bottom: 12rpx; }

.record-images { margin-top: 12rpx; }
.img-single-img { width: 400rpx; height: 300rpx; border-radius: 12rpx; display: block; }
.img-grid { display: flex; flex-wrap: wrap; gap: 8rpx; }
.img-grid-item {
  width: 198rpx;
  height: 198rpx;
  border-radius: 8rpx;
}
.img-grid-item-2{
  width: 240rpx;
  height: 240rpx;
}
.img-grid-item-4{
  width: 240rpx;
  height: 240rpx;
}

.empty-wrap { display: flex; justify-content: center; padding: 120rpx 0; }
.empty-text { font-size: 28rpx; color: #86868b; }


/* 时间筛选弹窗 */
.time-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
}
.time-modal-close {
  font-size: 28rpx;
  color: #86868b;
  padding: 8rpx;
}
.time-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d1d1f;
}
.time-modal-confirm {
  font-size: 28rpx;
  color: #007aff;
  font-weight: 600;
  padding: 8rpx;
}

.time-options {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 0 32rpx 24rpx;
}
.time-option {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #1d1d1f;
}
.time-option.active {
  background: #e8f4ff;
  color: #007aff;
  font-weight: 600;
}

.custom-date-section {
  padding: 0 32rpx 40rpx;
  border-top: 1rpx solid #f2f2f7;
  padding-top: 24rpx;
}
.custom-date-label {
  font-size: 26rpx;
  color: #86868b;
  display: block;
  margin-bottom: 16rpx;
}
.custom-date-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.date-picker{
  flex: 1;
}
.date-picker-btn {
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #c7c7cc;
}
.date-picker-btn.has-value {
  color: #1d1d1f;
}
.date-sep {
  font-size: 28rpx;
  color: #86868b;
  flex-shrink: 0;
}
