<!--pages/studentDetail/studentDetail.wxml-->
<wxs module="_filters">
  module.exports = {
    isTagActive: function(item, selectedTagIds) {
      return selectedTagIds.indexOf(item.id) !== -1;
    }
  };
</wxs>

<navBar title="学员详情" />
<layout>
  <view class="container">
    <!-- 学员信息 -->
    <view class="student-header">
      <view class="student-avatar">
        <image src="{{studentData.student.avatar_url}}" class="avatar-img"></image>
      </view>
      <view class="student-info">
        <view class="student-name">
          <text>{{studentData.student_name}}</text>
          <switch checked="{{bookingStatus}}" bindchange="bookingStatusSwitchChange"/>
        </view>
        <view class="student-tags" bindtap="onShowTagModal">
          <view wx:if="{{studentTags.length > 0}}" class="tag-chips">
            <view class="tag-chip tag-chip-min" wx:for="{{studentTags}}" wx:key="id">{{item.name}}</view>
          </view>
          <view wx:else class="add-tag-hint">
            <text class="add-tag-text">+ 添加标签</text>
          </view>
        </view>
      </view>
    </view>

    <view class="course-list">
      <!-- 基本资料 -->
      <view class="course-item active" bind:tap="handleEdit">
        <view class="course-item-left">
          <text class="iconfont icon-editor"></text>
          <text>基本资料</text>
        </view>
        <text class="iconfont icon-arrow-r arrow"></text>
      </view>
      <!-- 常规课管理 -->
      <view class="course-item active" bind:tap="handleRegularCourseManagement">
        <view class="course-item-left">
          <text class="iconfont icon-course"></text>
          <text>常规课管理</text>
        </view>
        <text class="iconfont icon-arrow-r arrow"></text>
      </view>

      <!-- 卡片管理 -->
      <view class="course-item active" bind:tap="handleCardManagement">
        <view class="course-item-left">
          <text class="iconfont icon-card"></text>
          <text>课程卡管理</text>
        </view>
        <text class="iconfont icon-arrow-r arrow"></text>
      </view>

      <!-- 训练计划 -->
      <view class="course-item active" bind:tap="handlePlanManagement">
        <view class="course-item-left">
          <text class="iconfont icon-order"></text>
          <text>训练计划</text>
        </view>
        <text class="iconfont icon-arrow-r arrow"></text>
      </view>

      <!-- 上课记录 -->
      <view class="course-item active" bind:tap="handleViewCourseList">
        <view class="course-item-left">
          <text class="iconfont icon-order"></text>
          <text>上课记录</text>
        </view>
        <text class="iconfont icon-arrow-r arrow"></text>
      </view>
    </view>

    <!-- 教练权限 -->
    <view class="info-section">
      <view class="permission-container">
        <view class="permission-text">
          <text>我发起的课程预约自动确认</text>
          <text class="iconfont icon-tishi" bind:tap="openPermissionTips"></text>
        </view>
        <text class="right-text">
          <text class="permission-text-opened" wx:if="{{studentData.auto_confirm_by_coach}}">已开启</text>
          <text wx:else>未开启</text>
        </text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <button class="book-button" bindtap="onBookStudent" disabled="{{isUnbinding}}">立即约课</button>
      <button class="unbind-button" bindtap="onShowUnbindConfirm" disabled="{{isUnbinding}}">
        {{isUnbinding ? '解除中...' : '解除绑定'}}
      </button>
    </view>
  </view>
</layout>

<!-- 标签选择弹窗 -->
<modal show="{{showTagModal}}" title="设置标签" position="bottom" bind:close="onHideTagModal">
  <view class="tag-select-body">
    <view wx:if="{{allTags.length > 0}}" class="tag-chips">
      <view
        class="tag-chip {{_filters.isTagActive(item, selectedTagIds) ? 'active' : ''}}"
        wx:for="{{allTags}}"
        wx:key="id"
        bindtap="onToggleTag"
        data-id="{{item.id}}"
      >{{item.name}}</view>
    </view>
    <view wx:else class="tag-select-empty">
      <text class="tag-select-empty-text">暂无标签，请先在「标签管理」中添加</text>
    </view>
    <view class="tag-manage-entry" bindtap="onManageOrRefreshTags">
      <text class="tag-manage-text">{{tagRefreshMode ? '刷新标签' : '管理标签'}}</text>
    </view>
  </view>
  <view class="tag-select-footer">
    <view class="tag-select-btn cancel" bindtap="onHideTagModal">取消</view>
    <view class="tag-select-btn confirm" bindtap="onSaveTags">保存</view>
  </view>
</modal>


<!-- 解除绑定确认弹窗 -->
<modal show="{{showUnbindModal}}" title="解除绑定" bind:close="onHideUnbindModal" maskClosable="{{false}}">
  <view class="unbind-modal-body">
    <view class="confirm-text">
      <text class="warning-icon">⚠️</text>
      <text class="confirm-message">确定要解除与"{{studentData.student.nickname}}"的师生关系吗？</text>
    </view>
    <view class="confirm-tips">
      <text class="tips-text">解除后将无法查看该学员信息，且无法恢复</text>
    </view>
  </view>
  <view class="modal-footer">
    <button class="cancel-btn" bindtap="onHideUnbindModal">取消</button>
    <button class="confirm-btn" bindtap="onConfirmUnbind" loading="{{isUnbinding}}">
      {{isUnbinding ? '解除中...' : '确认解除'}}
    </button>
  </view>
</modal>