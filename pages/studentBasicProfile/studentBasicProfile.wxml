<navBar title="基本资料" />
<layout>
  <view class="page-container">
    <view class="form-card">

      <view class="form-item">
        <text class="label">手机</text>
        <text class="value">{{studentData.student.phone || '-'}}</text>
      </view>

      <view class="form-item">
        <text class="label">姓名</text>
        <input
          class="input-value"
          type="text"
          maxlength="50"
          placeholder="请输入学员姓名"
          value="{{studentName}}"
          bindinput="onStudentNameInput"
        />
      </view>

      <view class="form-item" bindtap="onChooseGender">
        <text class="label">性别</text>
        <view class="value-container">
          <text class="value">{{genderText}}</text>
          <text class="iconfont icon-arrow-r"></text>
        </view>
      </view>

      <view class="form-item">
        <text class="label">身高（cm）</text>
        <input
          class="input-value"
          type="digit"
          placeholder="请输入身高"
          value="{{studentHeight}}"
          bindinput="onHeightInput"
        />
      </view>

      <view class="form-item">
        <text class="label">体重（kg）</text>
        <input
          class="input-value"
          type="digit"
          placeholder="请输入体重"
          value="{{studentWeight}}"
          bindinput="onWeightInput"
        />
      </view>

      <view class="form-item">
        <text class="label">生日</text>
        <picker mode="date" value="{{studentBirthday}}" bindchange="onBirthdayChange">
          <view class="value-container">
            <text class="value">{{studentBirthday || '请选择生日'}}</text>
            <text class="iconfont icon-arrow-r"></text>
          </view>
        </picker>
      </view>

      <view class="form-item remark-item">
        <textarea
          class="remark-textarea"
          maxlength="200"
          placeholder="这里填写对学员的备注，例如：仅工作日中午有时间上课"
          value="{{studentRemark}}"
          bindinput="onRemarkInput"
        />
      </view>
    </view>
  </view>
</layout>

<view class="submit-container">
  <button class="submit-btn" bindtap="onSubmit" loading="{{isSaving}}">
    <text>{{isSaving ? '提交中...' : '提交'}}</text>
  </button>
</view>
