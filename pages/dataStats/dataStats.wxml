<!--pages/dataStats/dataStats.wxml-->
<navBar title="数据统计" />
<layout>
  <view class="page-container">
    <!-- 时间筛选 -->
    <view class="filter-card">
      <view class="filter-row">
        <text class="filter-label">学员</text>
        <picker
          mode="selector"
          range="{{studentPickerRange}}"
          range-key="name"
          value="{{studentPickerIndex}}"
          bindchange="onStudentPickerChange"
        >
          <view class="filter-value">
            <text>{{selectedStudentName}}</text>
            <text class="iconfont icon-arrow-r"></text>
          </view>
        </picker>
      </view>
      <view class="filter-row" wx:if="{{selectedRangeKey === 'custom'}}">
        <text class="filter-label">开始日期</text>
        <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
          <view class="filter-value">
            <text>{{startDate || '不限'}}</text>
            <text class="iconfont icon-arrow-r"></text>
          </view>
        </picker>
      </view>
      <view class="filter-row" wx:if="{{selectedRangeKey === 'custom'}}">
        <text class="filter-label">结束日期</text>
        <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
          <view class="filter-value">
            <text>{{endDate || '不限'}}</text>
            <text class="iconfont icon-arrow-r"></text>
          </view>
        </picker>
      </view>
      <view class="quick-filters">
        <view
          class="quick-filter {{selectedRangeKey === item.key ? 'active' : ''}}"
          wx:for="{{rangeOptions}}"
          wx:key="key"
          bindtap="onSelectRange"
          data-key="{{item.key}}"
        >{{item.label}}</view>
      </view>
      <view class="filter-actions" wx:if="{{selectedRangeKey === 'custom'}}">
        <view class="filter-btn" bindtap="onClearDate">清除</view>
        <view class="filter-btn primary" bindtap="onApplyFilter">查询</view>
      </view>
    </view>

    <!-- 数据总览 -->
    <view class="section-card">
      <view class="section-title">数据总览</view>
      <view class="stats-grid">
        <view class="stats-item">
          <text class="stats-value">{{overview.completed_lessons}}</text>
          <text class="stats-label">已消课时数</text>
        </view>
        <view class="stats-item">
          <text class="stats-value">{{overview.completed_revenue}}</text>
          <text class="stats-label">消课收入（元）</text>
        </view>
        <view class="stats-item">
          <text class="stats-value">{{overview.remaining_lessons}}</text>
          <text class="stats-label">未消课时数</text>
        </view>
        <view class="stats-item">
          <text class="stats-value">{{overview.remaining_revenue}}</text>
          <text class="stats-label">未消课金额（元）</text>
        </view>
      </view>
    </view>

    <!-- 消课排行榜 -->
    <view class="section-card" wx:if="{{!selectedStudentId}}">
      <view class="section-title">消课排行榜</view>
      <view wx:if="{{ranking.length > 0}}" class="ranking-list">
        <view class="ranking-item" wx:for="{{ranking}}" wx:key="student_id">
          <view class="ranking-left">
            <text class="ranking-no">{{item.rank}}</text>
            <text class="ranking-name">{{item.student_name}}</text>
          </view>
          <text class="ranking-count">{{item.completed_lessons}} 节</text>
        </view>
      </view>
      <emptyState
        wx:elif="{{!loading}}"
        type="no-data"
        title="暂无排行数据"
        description="所选时间范围内暂无消课记录"
      />
    </view>
  </view>
</layout>
