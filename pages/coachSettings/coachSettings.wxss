/* pages/coachSettings/coachSettings.wxss */
@import '/style/iconfont.wxss';

page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.container {
  padding: 16rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* ── 分组卡片 ── */
.settings-section {
  background-color: #fff;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  height: 50rpx;
}

.section-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

/* ── 说明提示框（蓝色左边框） ── */
.hint-box {
  padding: 18rpx 20rpx;
  background-color: #e7f3ff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.hint-text {
  font-size: 24rpx;
  color: #007aff;
}

/* ── 设置项列表 ── */
.settings-content {
  display: flex;
  flex-direction: column;
}

.setting-item {
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 30rpx;
  color: #333;
}

/* ── Picker ── */
.picker-val {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 30rpx;
  color: #666;
}

.picker-arrow {
  font-size: 24rpx;
  color: #c7c7cc;
}

/* ── 次数输入 ── */
.row-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.count-input {
  width: 80rpx;
  height: 56rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  background: #fafafa;
}

.unit {
  font-size: 28rpx;
  color: #666;
}

/* ── 说明文字（蓝底提示卡） ── */
.config-tip {
  margin-top: 4rpx;
  padding: 16rpx 20rpx;
  background: #f0f7ff;
  border-radius: 12rpx;
}

.tip-text {
  font-size: 22rpx;
  color: #4a90e2;
  line-height: 1.7;
}

/* ── 完成方式选项行 ── */
.option-item {
  align-items: center;
  padding: 24rpx 0;
}

.option-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.option-label {
  font-size: 30rpx;
  color: #333;
}

.option-desc {
  font-size: 24rpx;
  color: #86868b;
  line-height: 1.5;
}

.check-icon {
  font-size: 36rpx;
  color: #007aff;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* ── 加载 ── */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding-top: 120rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* ── 底部保存按钮 ── */
.save-button-container {
  position: fixed;
  bottom: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  width: calc(100% - 48rpx);
  max-width: 600rpx;
  z-index: 999;
}

.save-button {
  width: 100%;
  height: 96rpx;
  background: #333;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-button:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.save-button::after {
  border: none;
}

.save-button.disabled {
  opacity: 0.6;
}
