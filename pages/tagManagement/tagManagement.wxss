/* pages/tagManagement/tagManagement.wxss */
@import '/style/iconfont.wxss';

page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.container {
  padding: 16rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* 标签列表 */
.tag-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.tag-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #f2f2f7;
}

.tag-item:last-child {
  border-bottom: none;
}

.tag-name {
  font-size: 30rpx;
  color: #1d1d1f;
  font-weight: 500;
}

.tag-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.edit-btn {
  color: #007aff;
  background: #e8f0fe;
}

.delete-btn {
  color: #ff3b30;
  background: #fff0ef;
}

/* 空状态 */
.empty-wrap {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
}

.empty-text {
  font-size: 28rpx;
  color: #86868b;
}

/* 新增按钮 */
.add-button-container {
  position: fixed;
  bottom: 100rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
}

.add-button {
  width: 100%;
  height: 96rpx;
  background-color: #333;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-button::after {
  border: none;
}

.add-button:active {
  transform: scale(0.98);
  opacity: 0.9;
}
/* 弹窗内表单 */
.tag-form {
  padding: 24rpx 32rpx 8rpx;
}

.tag-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #1d1d1f;
  border: 1rpx solid #e9ecef;
  box-sizing: border-box;
}

/* 弹窗底部操作 */
.modal-actions {
  display: flex;
  border-top: 1rpx solid #f2f2f7;
  margin-top: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.modal-btn.cancel {
  color: #86868b;
  border-right: 1rpx solid #f2f2f7;
}

.modal-btn.confirm {
  color: #007aff;
  font-weight: 600;
}
