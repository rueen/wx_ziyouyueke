<!--pages/studentList/studentList.wxml-->
<wxs module="_filters">
  module.exports = {
    isTagActive: function(item, filterTagIds) {
      return filterTagIds.indexOf(item.id) !== -1;
    }
  };
</wxs>

<navBar title="我的学员" />
<layout>
  <!-- 搜索框 -->
  <view class="search-container">
    <view class="search-box">
      <input 
        class="search-input"
        type="text"
        placeholder="搜索学员名称或手机号"
        value="{{keyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearchConfirm"
      />
      <view class="search-clear" wx:if="{{keyword}}" bindtap="onClearSearch">
        <text class="iconfont icon-close"></text>
      </view>
    </view>
    <view class="search-right" bindtap="onShowFilter">
      <view class="filter-active-dot" wx:if="{{filterTagIds.length > 0}}"></view>
      <text class="iconfont icon-shaixuan {{filterTagIds.length > 0 ? 'filter-active' : ''}}"></text>
    </view>
  </view>

  <!-- 学员列表 -->
  <view class="student-list" wx:if="{{students.length > 0}}">
    <view
      class="student-item {{item.relation_status === 2 ? 'student-item-pending' : ''}}"
      wx:for="{{students}}"
      wx:key="id"
      bindtap="onStudentDetail"
      data-student="{{item}}"
    >
      <!-- 头像 -->
      <view class="student-avatar">
        <studentAvatar
          avatarUrl="{{item.student ? item.student.avatar_url : ''}}"
          studentName="{{item.student_name}}"
          size="{{100}}"
        />
      </view>

      <view class="student-info">
        <view class="student-main-info">
          <text class="student-name">{{item.student_name || item.pending_phone}}</text>
          <!-- 待激活徽标 -->
          <view class="status-badge pending-badge" wx:if="{{item.relation_status === 2}}">
            <text class="status-text">待激活</text>
          </view>
          <!-- 已关闭徽标 -->
          <view class="status-badge status-cancelled" wx:elif="{{!item.booking_status}}">
            <text class="status-text">已关闭</text>
          </view>
        </view>
        <!-- 待激活学员显示录入的手机号 -->
        <view class="pending-phone-hint" wx:if="{{item.relation_status === 2}}">
          <text>{{item.pending_phone}}</text>
        </view>
        <!-- 标签 -->
        <view wx:if="{{item.tags.length > 0}}" class="tag-chips">
          <view class="tag-chip tag-chip-min" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="id">{{tag.name}}</view>
        </view>
      </view>

      <!-- 待激活不显示跳转箭头 -->
      <text wx:if="{{item.relation_status !== 2}}" class="iconfont icon-arrow-r arrow-icon"></text>
    </view>
    
    <!-- 加载更多提示 -->
    <view class="load-more-container" wx:if="{{hasMore || isLoading}}">
      <view class="load-more-item" wx:if="{{isLoading}}">
        <text class="loading-text">加载中...</text>
      </view>
      <view class="load-more-item" wx:elif="{{hasMore}}">
        <text class="load-more-text">上拉加载更多</text>
      </view>
    </view>
    
    <!-- 没有更多数据提示 -->
    <view class="no-more-container" wx:if="{{!hasMore && !isLoading && students.length > 0}}">
      <text class="no-more-text">已加载全部学员</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:elif="{{isLoading && students.length === 0}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:else>
    <emptyState 
      type="no-data"
      title="{{keyword ? '未找到相关学员' : '暂无学员'}}"
      description="{{keyword ? '请尝试其他关键词搜索' : '您还没有关联任何学员，下拉可刷新'}}">
    </emptyState>
  </view>

  <!-- 添加学员按钮 -->
  <view class="add-button-container">
    <button class="add-button" bindtap="onAddStudent">添加学员</button>
  </view>
</layout>

<!-- 标签筛选面板 -->
<modal show="{{showFilterPanel}}" title="筛选条件" position="top" bind:close="onHideFilter">
  <view class="filter-body">
    <view class="filter-section-header">
      <text class="filter-section-title">标签筛选</text>
      <text class="filter-refresh-btn" bindtap="onRefreshFilterTags">刷新</text>
    </view>
    <view class="tag-chips" wx:if="{{allTags.length > 0}}">
      <view
        class="tag-chip {{_filters.isTagActive(item, filterTagIds) ? 'active' : ''}}"
        wx:for="{{allTags}}"
        wx:key="id"
        bindtap="onToggleFilterTag"
        data-id="{{item.id}}"
      >{{item.name}}</view>
    </view>
    <view class="filter-empty" wx:else>
      <text class="filter-empty-text">暂无标签，请先在「标签管理」中添加</text>
    </view>
  </view>
  <view class="filter-footer">
    <view class="filter-footer-btn clear" bindtap="onClearFilter">清除</view>
    <view class="filter-footer-btn search" bindtap="onApplyFilter">搜索</view>
  </view>
</modal>


<!-- 分享弹窗 -->
<shareModal 
  show="{{showShareModal}}"
  options="{{shareOptions}}"
  bind:close="onCloseShareModal"
  bind:select="onSelectShareType"
/>

<!-- 手动录入学员弹窗 -->
<view wx:if="{{showAddByPhoneModal}}" class="abp-mask" bindtap="onHideAddByPhoneModal">
  <view class="abp-modal" catchtap="onPreventClose">
    <view class="abp-header">
      <text class="abp-title">手动录入学员</text>
      <text class="iconfont icon-close abp-close" bindtap="onHideAddByPhoneModal"></text>
    </view>

    <view class="abp-body">
      <!-- 手机号 -->
      <view class="abp-field">
        <view class="abp-label">手机号 <text class="abp-required">*</text></view>
        <input
          class="abp-input"
          type="number"
          maxlength="11"
          placeholder="请输入学员手机号"
          value="{{addByPhoneForm.phone}}"
          data-field="phone"
          bindinput="onAddByPhoneInput"
        />
      </view>

      <!-- 姓名 -->
      <view class="abp-field">
        <view class="abp-label">姓名 <text class="abp-required">*</text></view>
        <input
          class="abp-input"
          type="text"
          placeholder="教练自定义学员称呼"
          value="{{addByPhoneForm.student_name}}"
          data-field="student_name"
          bindinput="onAddByPhoneInput"
        />
      </view>

      <!-- 备注 -->
      <view class="abp-field">
        <view class="abp-label">备注</view>
        <textarea
          class="abp-textarea"
          placeholder="选填，教练内部备注"
          value="{{addByPhoneForm.coach_remark}}"
          data-field="coach_remark"
          bindinput="onAddByPhoneInput"
          maxlength="200"
        ></textarea>
      </view>

      <view class="abp-tips">
        <text>• 已注册：直接建立正式师生关系</text>
        <text>• 未注册：创建待激活关系，学员绑定手机号后自动激活</text>
      </view>
    </view>

    <view class="abp-footer">
      <view class="abp-btn abp-btn-cancel" bindtap="onHideAddByPhoneModal">取消</view>
      <view class="abp-btn abp-btn-primary" bindtap="onSubmitAddByPhone">
        <text wx:if="{{!isSubmittingByPhone}}">确认添加</text>
        <text wx:else>添加中...</text>
      </view>
    </view>
  </view>
</view>
