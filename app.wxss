/**
 * app.wxss
 * 全局样式
 */

/* 重置默认样式 */
@import '/style/common.wxss';

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Open Sans', 'Helvetica Neue', sans-serif;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}
switch, radio {
  transform: scale(0.8);
}
.iconfont.icon-arrow-r{
  font-size: 26rpx;
  color: #666;
}

/* 学生标签 */
.tag-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-chip {
  padding: 12rpx 28rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  font-size: 26rpx;
  color: #333;
}

.tag-chip.active {
  background: #fbefde;
  color: #ff9500;
}

.tag-chip-min{
  padding: 6rpx 14rpx;
  font-size: 24rpx;
}