/**
 * app.wxss
 * 全局样式
 */

/* 重置默认样式 */
@import '/style/common.wxss';

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Open Sans', 'Helvetica Neue', sans-serif;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}
switch, radio {
  transform: scale(0.8);
}
.iconfont.icon-arrow-r{
  font-size: 26rpx;
  color: #666;
}

/* 学生标签 */
.tag-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-chip {
  padding: 12rpx 28rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  font-size: 26rpx;
  color: #333;
}

.tag-chip.active {
  background: #fbefde;
  color: #ff9500;
}

.tag-chip-min{
  padding: 6rpx 14rpx;
  font-size: 24rpx;
}

/* 悬浮按钮 */
.btn-fixed {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #333;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  z-index: 99;
}

.btn-fixed:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.btn-fixed-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}
.btn-fixed .iconfont{
  color: #fff;
  font-size: 40rpx;
}

/* 添加按钮 */
.add-button-container {
  position: fixed;
  bottom: 100rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
}

.add-button {
  width: 100%;
  height: 96rpx;
  background-color: #333;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-button::after {
  border: none;
}

.add-button:active {
  transform: scale(0.98);
  opacity: 0.9;
}