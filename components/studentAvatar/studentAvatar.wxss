.student-avatar {
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  background-color: #f5f5f5;
}

.avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

.avatar-text {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text-content {
  color: #ffffff;
  font-weight: 500;
  line-height: 1;
}
