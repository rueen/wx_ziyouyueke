/* components/timeSelector/timeSelector.wxss */
@import '/style/common.wxss';
@import '/style/iconfont.wxss';

/* 日期选择器样式 */
.date-selector {
  background-color: #fff;
  padding: 16rpx;
}

.date-scroll {
  width: 100%;
}

.date-list {
  display: flex;
  white-space: nowrap;
}

.date-item {
  flex-shrink: 0;
  width: 120rpx;
  height: 140rpx;
  margin-right: 20rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.3s ease;
}

.date-item.active {
  background-color: #007aff;
  color: #fff;
}

.date-item.full {
  background-color: #f0f0f0;
  color: #999;
}

.date-item.active.full {
  background-color: #ff6b6b;
  color: #fff;
}

.date-weekday {
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.date-monthday {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.date-status {
  font-size: 20rpx;
}

.today-indicator {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background-color: #ff4757;
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 6rpx;
  border-radius: 8rpx;
}

.date-item.active .today-indicator {
  background-color: rgba(255, 255, 255, 0.3);
}

/* 时间段容器样式 */
.time-slots-container {
  flex: 1;
  padding: 16rpx;
}

/* 自由时间选择器样式 */

.free-time-hint {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx;
  background-color: #e7f3ff;
  border-left: 6rpx solid #007aff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.hint-text {
  flex: 1;
  font-size: 24rpx;
  color: #007aff;
  line-height: 1.6;
}

.time-selection-card {
  background-color: #ffffff;
  border-radius: 16rpx;
}

.selection-header {
  margin-bottom: 32rpx;
}

.header-title {
  font-size: 32rpx;
  color: #1d1d1f;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.time-picker-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.time-picker-item {
  flex: 1;
}

.picker-view {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-radius: 12rpx;
  border: 1rpx solid #007aff;
}

.picker-text {
  font-size: 28rpx;
  color: #c7c7cc;
}

.picker-text.selected {
  color: #1d1d1f;
  font-weight: 500;
}

.icon-rightarrow {
  font-size: 24rpx;
  color: #c7c7cc;
}

.separator-text {
  font-size: 28rpx;
  color: #86868b;
}

.hint-complete-text {
  font-size: 24rpx;
  color: #155724;
  font-weight: 500;
}

/* 已预约时间段展示区域（自由时间选择模式） */
.booked-timeslots-section {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background-color: #fff3cd;
  border-radius: 12rpx;
  border-left: 6rpx solid #ffc107;
}

.booked-timeslots-section .section-header {
  margin-bottom: 16rpx;
}

.booked-timeslots-section .section-title {
  font-size: 28rpx;
  color: #856404;
  font-weight: 600;
  display: block;
  margin-bottom: 4rpx;
}

.booked-timeslots-section .section-subtitle {
  font-size: 22rpx;
  color: #856404;
  display: block;
}

/* 时间段列表 */
.timeslots-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.timeslot-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  border: 2rpx solid #ffc107;
}

.timeslot-item.has-group {
  border-color: #ff9500;
  background-color: #fff8f5;
}

.timeslot-time {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.time-range {
  font-size: 24rpx;
  color: #1d1d1f;
  font-weight: 500;
}

.timeslot-badge {
  padding: 2rpx 8rpx;
  background-color: #ff9500;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
}

.timeslot-badge .badge-text {
  font-size: 20rpx;
  color: #ffffff;
}

.timeslot-count {
  padding-left: 8rpx;
  border-left: 2rpx solid #e5e5ea;
}

.count-text {
  font-size: 22rpx;
  color: #86868b;
}

/* 加载状态样式 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 200rpx;
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

/* 空状态样式 */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 200rpx;
  color: #999;
  font-size: 28rpx;
}

/* 时间段列表样式 */
.time-slots {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.time-slot {
  background-color: #fff;
  padding: 24rpx;
  display: flex;
  align-items: center;
  position: relative;
  transition: all 0.3s ease;
  min-height: 130rpx;
  border-bottom: 1rpx solid #f5f5f5;
  box-sizing: border-box;
}

.time-slot.free::before {
  background-color: #ddd;
}

.time-slot.selectable {
  cursor: pointer;
}
.time-slot.selected .icon-selected{
  color: #007aff;
  font-size: 40rpx;
}

.time-slot-time {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  min-width: 260rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.quota-statistics{
  font-size: 24rpx;
  font-weight: normal;
  background-color: #f2f2f2;
  width: 140rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 6rpx;
}

.time-slot-content {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 已预约状态样式 */
.booked-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.student-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.student-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.location-info {
  font-size: 24rpx;
  color: #666;
}

.location-info .iconfont{
  font-size: 26rpx;
  margin-right: 10rpx;
}

/* 空闲状态样式 */
.free-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.free-text {
  font-size: 28rpx;
  color: #999;
}

.select-hint {
  font-size: 24rpx;
  color: #007aff;
  background-color: #e6f3ff;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
}

/* 过期时间段样式 */
.time-slot.expired {
  background-color: #f8f9fa;
  opacity: 0.8;
  /* pointer-events: none; */
}

.time-slot.expired .time-slot-time {
  color: #c7c7cc;
}

.time-slot.expired .free-text {
  color: #c7c7cc;
}

.time-slot.expired .select-hint {
  display: none;
}

.time-slot.expired-booked {
  background-color: #f8f9fa;
  opacity: 0.6;
}

.time-slot.expired-booked .time-slot-time {
  color: #c7c7cc;
}

.time-slot.expired-booked .student-name {
  color: #c7c7cc;
}

.time-slot.expired-booked .location-info {
  color: #c7c7cc;
}

.time-slot.expired-booked .booked-text {
  color: #c7c7cc;
}

/* 已取消课程的样式 */
.time-slot.free-with-cancelled {
  background-color: #fff;
  border: 1rpx dashed #e5e5ea;
}

.cancelled-course {
  opacity: 0.7;
}

.cancelled-course .student-name.cancelled {
  color: #8e8e93;
  text-decoration: line-through;
}

.cancelled-course .location-info.cancelled {
  color: #8e8e93;
}

.rebook-hint {
  margin-top: 12rpx;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.rebook-hint .select-hint {
  font-size: 22rpx;
  color: #34c759;
  background-color: #e8f5e8;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
}

/* 名额统计样式 */
.quota-info {
  display: flex;
  align-items: center;
}

.quota-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.remaining-text {
  font-size: 24rpx;
  color: #34c759;
  margin-left: 8rpx;
}

.full-text {
  font-size: 24rpx;
  color: #ff6b6b;
  margin-left: 8rpx;
}

/* 课程列表样式 */
.courses-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  width: 100%;
}

.course-item {
  padding: 12rpx;
}

.course-item .student-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.course-item .student-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.course-item .location-info {
  font-size: 22rpx;
  color: #666;
}

.course-item .location-info .iconfont {
  font-size: 24rpx;
  margin-right: 8rpx;
}

/* 无课程提示样式 */
.no-courses {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
}

.no-courses-text {
  font-size: 26rpx;
  color: #999;
}

/* 选择提示容器样式 */
.select-hint-container {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-top: 8rpx;
}

/* 过期和满员状态样式 */
.expired-text {
  font-size: 28rpx;
  color: #c7c7cc;
}

.too-soon-text {
  font-size: 24rpx;
  color: #ff9500;
  font-weight: 500;
}

.full-text {
  font-size: 28rpx;
  color: #ff6b6b;
}

/* 简化的已预约状态样式 */
.booked-simple {
  display: flex;
  align-items: center;
}

.booked-text {
  font-size: 28rpx;
  color: #666;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .date-item {
    width: 100rpx;
    height: 120rpx;
  }
  
  .date-weekday {
    font-size: 22rpx;
  }
  
  .date-monthday {
    font-size: 26rpx;
  }
  
  .date-status {
    font-size: 18rpx;
  }
  
  .time-slot-time {
    font-size: 30rpx;
    min-width: 180rpx;
  }
  
  .student-name {
    font-size: 26rpx;
  }
  
  .free-text {
    font-size: 26rpx;
  }
} 

.template-status {
  margin: 20rpx;
  padding: 16rpx 20rpx;
  background-color: #fff3cd;
  border: 1rpx solid #ffeaa7;
  border-radius: 12rpx;
}

.status-text {
  font-size: 26rpx;
  color: #856404;
}

/* 活动样式 */
.group-course {
  border-left: 4rpx solid #b1dd01;
  background-color: #fbfdf2;
}

.group-course-info {
  width: 100%;
}

.group-course-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.group-course-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1d1d1f;
  flex: 1;
  margin-right: 12rpx;
}

.group-badge {
  display: flex;
  align-items: center;
  background-color: #cff632;
  color: #000;
  padding: 6rpx 12rpx;
  border-radius: 10rpx;
}

.group-badge .badge-text {
  font-size: 22rpx;
}

.group-course-details {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.group-course-coach,
.group-course-location {
  display: flex;
  align-items: center;
  color: #666;
  font-size: 24rpx;
}

.group-course-coach .iconfont,
.group-course-location .iconfont {
  margin-right: 8rpx;
  font-size: 20rpx;
}

.group-course-stats {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.participants {
  font-size: 24rpx;
  color: #666;
}

.price {
  font-size: 24rpx;
  font-weight: 600;
  color: #ff6b35;
}

/* 个人课程样式 */
.personal-course {
  border-left: 4rpx solid #007aff;
}

/* 活动模式样式 */
.booked-text {
  color: #ff9500;
  font-weight: 500;
}

.free-text {
  color: #34c759;
  font-weight: 500;
}

.group-booked-text {
  color: #ff9500;
  font-weight: 500;
  font-size: 28rpx;
}

/* ===== 休息时段样式 ===== */

/* time-slot-time 内部拆分为标签行和操作行 */
.slot-time-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.slot-time-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

/* 休息中标记（小徽章，显示在时间文字旁） */
.rest-badge {
  font-size: 18rpx;
  color: #fff;
  background-color: #ff9c9c;
  padding: 2rpx 8rpx;
  border-radius: 20rpx;
  font-weight: 400;
  line-height: 1.4;
}

/* 休息按钮（view 模式教练操作） */
.rest-btn {
  font-size: 22rpx;
  background-color: #f0f9ff;
  height: 40rpx;
  display: flex;
  align-items: center;
  padding: 0 12rpx;
  border-radius: 20rpx;
  background: #fff2f0;
  color: #ff4d4f;
  border: 1rpx solid #ffccc7;
  box-sizing: border-box;
}

/* 已休息时"取消休息"按钮样式 */
.rest-btn-cancel{
  background: #f5f5f5;
  color: #888;
  border-color: #e0e0e0;
}

/* 时间段整体休息状态背景 */
.time-slot.resting {
  background-color: #fafafa;
  opacity: 0.85;
}

.time-slot.resting::before {
  background-color: #ffcccc !important;
}

/* select 模式下休息中文案 */
.resting-text {
  font-size: 24rpx;
  color: #ff6b6b;
  font-weight: 500;
}

/* ===== 结构化自由日程网格样式 ===== */

.structured-free-wrapper {
  padding: 0 4rpx;
}

.structured-hint {
  padding: 0 0 12rpx;
}

.structured-hint-text {
  font-size: 26rpx;
  color: #888;
}

/* 5列网格 */
.slots-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.grid-slot {
  /* 4列，减去3个间距 */
  width: calc((100% - 42rpx) / 4);
  aspect-ratio: 8 / 5;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  background: #fff;
  box-sizing: border-box;
}

.grid-slot-time {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  text-align: center;
}

/* 可选 */
.grid-slot.free {
  background: #0b81ff0e;
}

/* 有预约但未满 */
.grid-slot.booked {
  background: #fff8ee;
}
.grid-slot.booked .grid-slot-time {
  color: #d46b08;
}

/* 已满 */
.grid-slot.full {
  background: #dadada;
  opacity: 0.6;
}
.grid-slot.full .grid-slot-time {
  color: #777;
}

/* 冲突（select 模式：本身无课程但预约会冲突） */
.grid-slot.conflict {
  background: #f5f5f5;
  opacity: 0.6;
}
.grid-slot.conflict .grid-slot-time {
  color: #999;
}

/* 休息 */
.grid-slot.resting {
  background: #dadada;
  opacity: 0.6;
}
.grid-slot.resting .grid-slot-time {
  color: #777;
}

/* 已过期 */
.grid-slot.expired {
  background: #dadada;
  opacity: 0.6;
}
.grid-slot.expired .grid-slot-time {
  color: #777;
}

/* 提前预约限制 */
.grid-slot.tooSoon {
  background: #dadada;
  opacity: 0.6;
}
.grid-slot.tooSoon .grid-slot-time {
  color: #777;
}

/* 活动占用 */
.grid-slot.groupBooked {
  background: #f5f5f5;
}
.grid-slot.groupBooked .grid-slot-time {
  color: #aaa;
}

/* 当前选中 */
.grid-slot.grid-selected {
  background: #e6f0ff;
  border-color: #4a90e2;
  border-width: 2rpx;
}
.grid-slot.grid-selected .grid-slot-time {
  color: #1565c0;
  font-weight: 600;
}

/* ---- 右下角斜角状态徽章 ---- */
.grid-badge-wrap {
  position: absolute;
  bottom: 0;
  right: 0;
  padding: 0 8rpx;
  height: 30rpx;
  display: flex;
  align-items: center;
  background: #ddd;
}

.grid-badge-wrap.full      { background: #ff7a45; }
.grid-badge-wrap.resting   { background: #ff9c9c; }
.grid-badge-wrap.expired   { background: #c0c0c0; }
.grid-badge-wrap.tooSoon   { background: #ffa940; }
.grid-badge-wrap.groupBooked { background: #cff632; }
.grid-badge-wrap.groupBooked .grid-badge-label { color: #000; }
.grid-badge-wrap.booked    { background: #69b1ff; }

/* 徽章文字 */
.grid-badge-label {
  font-size: 18rpx;
  color: #fff;
  font-weight: 600;
  line-height: 1;
}

/* ===== 网格时间段详情面板（modal slot 内容） ===== */

.gd-body {
  padding: 8rpx 0 16rpx;
}

/* 顶部信息栏：休息中标记 + 名额 + 休息按钮 */
.gd-info-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 16rpx 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 16rpx;
  gap: 16rpx;
}

.gd-info-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.gd-rest-badge {
  font-size: 18rpx;
  color: #fff;
  background-color: #ff9c9c;
  padding: 2rpx 8rpx;
  border-radius: 20rpx;
  font-weight: 400;
  line-height: 1.4;
}

.gd-quota {
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.gd-rest-btn {
  flex-shrink: 0;
  padding: 10rpx 26rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  background: #fff2f0;
  color: #ff4d4f;
  border: 1rpx solid #ffccc7;
  line-height: 1.4;
}

.gd-rest-btn-cancel {
  background: #f5f5f5;
  color: #888;
  border-color: #e0e0e0;
}

/* 课程列表 */
.gd-courses {
  display: flex;
  flex-direction: column;
}

.gd-course-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
  gap: 16rpx;
}

.gd-course-item:last-child {
  border-bottom: none;
}

.gd-personal-info,
.gd-group-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.gd-group-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.gd-group-stats {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.gd-group-participants {
  font-size: 24rpx;
  color: #888;
}

.gd-group-price {
  font-size: 24rpx;
  color: #fa8c16;
}

.gd-student-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.gd-student-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #222;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.gd-location {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.gd-location-icon {
  font-size: 22rpx;
  color: #aaa;
}

.gd-location-text {
  font-size: 24rpx;
  color: #888;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.gd-arrow {
  font-size: 24rpx;
  color: #ccc;
  flex-shrink: 0;
}

/* 无课程提示 */
.gd-empty {
  padding: 48rpx 0;
  text-align: center;
}

.gd-empty-text {
  font-size: 28rpx;
  color: #bbb;
}